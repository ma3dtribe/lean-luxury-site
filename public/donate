<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />

<title>Support MA3DTribe</title>

<style>
:root{
  --bg:#050505;
  --card:#111;
  --border:rgba(255,255,255,.10);
  --text:#f5f5f5;
  --muted:rgba(255,255,255,.72);
  --red:#ff2d2d;
}

*{
  box-sizing:border-box;
}

body{
  margin:0;
  background:var(--bg);
  color:var(--text);
  font-family:Inter,system-ui,sans-serif;
  overflow-x:hidden;
}

.page{
  width:min(1100px,100%);
  margin:auto;
  padding:28px 18px 120px;
}

.hero{
  text-align:center;
  margin-bottom:28px;
}

.hero h1{
  margin:0 0 10px;
  font-size:clamp(38px,6vw,72px);
  font-weight:900;
}

.hero p{
  margin:0;
  color:var(--muted);
  font-size:18px;
  line-height:1.5;
}

.grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:22px;
}

@media (max-width:980px){
  .grid{
    grid-template-columns:1fr;
  }
}

.mobile-only{
  display:none;
}

.desktop-only{
  display:block;
}

@media (max-width:980px){

  .mobile-only{
    display:flex !important;
    align-items:center;
    justify-content:center;
    text-decoration:none;
  }

  .desktop-only{
    display:none !important;
  }

}

.card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:24px;
  padding:28px;
}

.card h2{
  margin:0 0 12px;
  font-size:32px;
  font-weight:900;
}

.card p{
  color:var(--muted);
  line-height:1.6;
}

.email-box{
  margin-top:20px;
  border:1px solid var(--border);
  border-radius:18px;
  padding:18px;
  text-align:center;
  background:rgba(255,255,255,.03);
}

.email{
  font-size:clamp(22px,4vw,42px);
  font-weight:900;
  word-break:break-word;
}

.copy-btn{
  margin-top:18px;
  width:100%;
  border:0;
  border-radius:14px;
  background:var(--red);
  color:white;
  min-height:56px;
  font-size:18px;
  font-weight:900;
  cursor:pointer;
}

.qr-wrap{
  text-align:center;
}

.qr-wrap img{
  width:min(100%,420px);
  border-radius:22px;
  display:block;
  margin:auto;
}

.coming{
  opacity:.7;
  margin-top:18px;
}

.back{
  margin-top:32px;
  display:flex;
  justify-content:center;
}

.back a{
  text-decoration:none;
  color:white;
  border:1px solid rgba(255,255,255,.18);
  border-radius:999px;
  padding:14px 24px;
  font-weight:800;
}
</style>
</head>

<body>

<div class="page">

  <div class="hero">
    <h1>Support MA3DTribe</h1>

    <p>
      Your support helps keep the music, live shows,
      podcasts, and culture going strong.
    </p>
  </div>

  <div class="grid" style="grid-template-columns:1fr 1fr 1fr;">

    <!-- ZELLE -->
    <div class="card">

      <h2>Zelle</h2>

      <p>
        Send support directly using Zelle.
      </p>

      <div class="email-box">

        <div class="email" id="zelleEmail">
          ma3dlegacy@gmail.com
        </div>

        <button class="copy-btn" id="copyBtn">
          Copy Zelle Email
        </button>

      </div>

    </div>

   <div class="card qr-wrap">

  <h2>Venmo</h2>

  <p class="desktop-only">
    Scan with your phone camera or Venmo app.
  </p>

  <img
    class="desktop-only"
    src="/images/venmo-qr.png"
    alt="Venmo QR Code"
  />

  <a
    class="copy-btn mobile-only"
    href="https://venmo.com/"
    target="_blank">
    Open Venmo
  </a>

</div>

<div class="card qr-wrap">

  <h2>Cash App</h2>

  <p class="desktop-only">
    Scan with your camera or Cash App.
  </p>

  <img
    class="desktop-only"
    src="/images/cashapp-qr.png"
    alt="Cash App QR Code"
  />

  <a
    class="copy-btn mobile-only"
    href="https://cash.app/"
    target="_blank">
    Open Cash App
  </a>

</div>

  </div>

  <div class="back">
    <a href="/">
      ← Back to Home
    </a>
  </div>

</div>

<script>
document.getElementById("copyBtn").addEventListener("click", async () => {

  const email =
    document.getElementById("zelleEmail").innerText.trim();

  try{
    await navigator.clipboard.writeText(email);

    const btn = document.getElementById("copyBtn");

    btn.innerText = "Copied!";

    setTimeout(() => {
      btn.innerText = "Copy Zelle Email";
    }, 2000);

  }catch(e){
    alert(email);
  }
});
</script>

</body>
</html>
